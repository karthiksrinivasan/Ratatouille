    {
      "type": "text",
      "id": "phase2_title",
      "x": 440,
      "y": 150,
      "width": 320,
      "height": 220,
      "text": "2. Confirm & Get\nSuggestions\n\n\u2022 Edit ingredient chips\n   (confidence-coded)\n\u2022 Dual-lane suggestions:\n   Saved + Buddy-generated\n\u2022 Gemini Flash generates\n   recipe ideas\n\u2022 \"Why this recipe?\" grounding",
      "originalText": "2. Confirm & Get\nSuggestions\n\n\u2022 Edit ingredient chips\n   (confidence-coded)\n\u2022 Dual-lane suggestions:\n   Saved + Buddy-generated\n\u2022 Gemini Flash generates\n   recipe ideas\n\u2022 \"Why this recipe?\" grounding",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#374151",
