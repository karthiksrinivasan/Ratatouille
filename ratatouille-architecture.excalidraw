    {
      "type": "text",
      "id": "phase1_title",
      "x": 90,
      "y": 150,
      "width": 280,
      "height": 220,
      "text": "1. Sign In &\nScan Fridge\n\n\u2022 Firebase Auth login\n\u2022 Capture 2-6 photos\n   or short video\n\u2022 Upload to GCS\n\u2022 Gemini Vision detects\n   ingredients + confidence",
      "originalText": "1. Sign In &\nScan Fridge\n\n\u2022 Firebase Auth login\n\u2022 Capture 2-6 photos\n   or short video\n\u2022 Upload to GCS\n\u2022 Gemini Vision detects\n   ingredients + confidence",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
