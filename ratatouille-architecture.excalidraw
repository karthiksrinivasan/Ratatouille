    {
      "type": "text",
      "id": "phase3_title",
      "x": 830,
      "y": 150,
      "width": 360,
      "height": 220,
      "text": "3. Live Cooking Session\n(Voice-Primary)\n\n\u2022 Gemini Live: real-time\n   bidirectional audio\n\u2022 ADK Orchestrator routes\n   to specialist agents\n\u2022 Barge-in interruption (VM-04)\n\u2022 Adaptive calibration\n\u2022 WebSocket for all real-time events",
      "originalText": "3. Live Cooking Session\n(Voice-Primary)\n\n\u2022 Gemini Live: real-time\n   bidirectional audio\n\u2022 ADK Orchestrator routes\n   to specialist agents\n\u2022 Barge-in interruption (VM-04)\n\u2022 Adaptive calibration\n\u2022 WebSocket for all real-time events",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#ffffff",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
